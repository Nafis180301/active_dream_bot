# ====================================
# Active Dream Bot Configuration
# ====================================
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin Telegram User IDs (comma-separated)
ADMIN_IDS=123456789

# 5sim.net API Key (get from https://5sim.net/profile)
FIVESIM_API_KEY=your_5sim_api_key_here

# OTP Group Settings
OTP_GROUP_ID=-1001234567890
OTP_GROUP_LINK=https://t.me/ActiveDreamOTP

# Channel Settings
CHANNEL_LINK=https://t.me/ActiveDreamChannel

# Bot Display Name
BOT_NAME=Active Dream

# OTP Settings
OTP_CHECK_INTERVAL=5
OTP_MAX_WAIT=300
